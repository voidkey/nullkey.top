---
<header class="flex-none flex items-stretch border-b border-border bg-bg-2 text-[11px] tracking-wider z-[5]">
  <div class="seg lead">
    <span class="text-accent italic font-serif text-[13px] leading-none">/</span><b>nullkey</b>
  </div>
  <div class="seg hidden sm:flex">
    <span class="text-mute">[0]</span><span class="text-text">home</span>
  </div>
  <div class="seg hidden sm:flex">
    <span class="text-mute">[1]</span>projects
  </div>
  <div class="seg hidden md:flex">
    <span class="text-mute">[2]</span>now
  </div>
  <div class="seg hidden md:flex">
    <span class="text-mute">[3]</span>uses
  </div>
  <div class="seg flex-1 justify-end" style="border-right:none;">
    <span class="hidden sm:inline-flex items-center gap-1.5 mr-3">
      <span class="pulse-dot"></span>online
    </span>
    <span class="hidden sm:inline mr-3">tty <b>s001</b></span>
    <span class="hidden md:inline mr-3">utf-8</span>
    <span id="clock" class="text-dim">--:--</span>
  </div>
</header>
