---
import ThemeSwitcher from '~/components/ThemeSwitcher.astro';

export interface Props {
  mode?: 'home' | 'posts' | 'reading';
  breadcrumb?: string;
  showBack?: boolean;
}
const { mode = 'home', breadcrumb, showBack = false } = Astro.props;

const tabs = [
  { id: 0, label: 'home',     href: '/',       active: mode === 'home' },
  { id: 1, label: 'posts',    href: '/posts/', active: mode === 'posts' || mode === 'reading' },
];
---
<header class="flex-none flex items-stretch border-b border-border bg-bg-2 text-[11px] tracking-wider z-[5] overflow-x-auto">
  <a href="/" class="seg lead hover:bg-bg-raised transition-colors" style="text-decoration:none;">
    <span class="text-accent italic font-serif text-[13px] leading-none">/</span><b>nullkey</b>
  </a>
  {tabs.map((t) => (
    <a
      href={t.href}
      class={`seg hidden sm:flex hover:text-text transition-colors ${t.active ? 'text-text' : ''}`}
      style="text-decoration:none;"
    >
      <span class="text-mute">[{t.id}]</span>{t.label}
    </a>
  ))}
  {breadcrumb && (
    <div class="seg hidden md:flex text-dim truncate max-w-[36ch]">
      <span class="text-mute">›</span><span class="text-text truncate">{breadcrumb}</span>
    </div>
  )}
  <div class="seg flex-1 justify-end gap-3">
    {showBack && (
      <a href="/" class="text-accent hover:text-text transition-colors" style="text-decoration:none;" id="back-home">
        ❮ esc · back
      </a>
    )}
    <span class="hidden md:inline-flex items-center gap-1.5">
      <span class="pulse-dot"></span>online
    </span>
    <span id="clock" class="text-dim">--:--</span>
  </div>
  <ThemeSwitcher />
</header>

<script is:inline>
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && document.getElementById('back-home')) {
      window.location.href = '/';
    }
  });
</script>
